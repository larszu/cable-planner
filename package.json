{
    "name": "cable-planner",
    "private": true,
    "version": "7.9.28",
    "description": "Electron desktop app for planning and visualizing broadcast equipment cabling",
    "author": {
        "name": "Lars Zumpe",
        "email": "lars@zumpe.dev"
    },
    "type": "module",
    "main": "dist/main/index.js",
    "scripts": {
        "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:electron\"",
        "dev:renderer": "vite",
        "dev:main": "tsc -p tsconfig.main.json --watch",
        "dev:preload": "tsc -p tsconfig.preload.json --watch",
        "dev:electron": "wait-on http-get://localhost:5173 dist/main/index.js dist/main/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
        "build": "npm run build:main && npm run build:preload && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:preload": "tsc -p tsconfig.preload.json",
        "build:renderer": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "dist": "npm run build && electron-builder"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@types/qrcode": "^1.5.5",
        "atem-connection": "^3.9.0",
        "axios": "^1.13.1",
        "fast-xml-parser": "^5.8.0",
        "html-to-image": "^1.11.13",
        "jspdf": "^4.2.1",
        "keytar": "^7.9.0",
        "qrcode": "^1.5.4",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "reactflow": "^11.11.4",
        "uuid": "^14.0.0",
        "xlsx-js-style": "^1.2.0",
        "yaml": "^2.8.3",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.4",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.1.15",
        "@types/node": "^25.8.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "autoprefixer": "^10.4.21",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^42.1.0",
        "electron-builder": "^26.0.12",
        "eslint": "^10.4.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "png-to-ico": "^3.0.1",
        "postcss": "^8.5.6",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.1.15",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.9",
        "wait-on": "^9.0.1"
    }
}
