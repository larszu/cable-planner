{
  "name": "cable-planner",
  "private": true,
  "version": "8.2.1",
  "description": "Electron desktop app for planning and visualizing broadcast equipment cabling",
  "author": {
    "name": "Lars Zumpe",
    "email": "lars@zumpe.dev"
  },
  "license": "MIT",
  "homepage": "https://larszu.github.io/cable-planner/",
  "repository": {
    "type": "git",
    "url": "https://github.com/larszu/cable-planner.git"
  },
  "bugs": {
    "url": "https://github.com/larszu/cable-planner/issues"
  },
  "keywords": [
    "broadcast",
    "cable-management",
    "cable-planner",
    "signal-flow",
    "sdi",
    "atem",
    "blackmagic",
    "videohub",
    "multiviewer",
    "live-production",
    "ob-van",
    "video-engineering",
    "rentman",
    "electron",
    "react",
    "react-flow",
    "typescript",
    "offline-first"
  ],
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:electron": "wait-on http-get://localhost:5173 dist/main/index.js dist/main/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui:smoke": "node scripts/ui-smoke.mjs",
    "test:drag": "node scripts/drag-test.mjs",
    "docs:stats": "node scripts/update-doc-stats.mjs",
    "test:crdt": "node scripts/crdt-convergence-check.mjs",
    "test:signaling": "npm run build:main && node scripts/signaling-relay-check.mjs",
    "dist": "npm run build && electron-builder",
    "notices": "node scripts/generate-notices.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/qrcode": "^1.5.6",
    "atem-connection": "^3.9.0",
    "axios": "^1.18.1",
    "bonjour-service": "^1.4.2",
    "electron-updater": "^6.8.9",
    "fast-xml-parser": "^5.9.3",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "keytar": "^7.9.0",
    "lucide-react": "^1.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reactflow": "^11.11.4",
    "three": "^0.185.0",
    "three-stdlib": "^2.36.1",
    "uuid": "^14.0.1",
    "xlsx-js-style": "^1.2.0",
    "y-webrtc": "^10.3.0",
    "yaml": "^2.9.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "playwright-core": "^1.61.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
